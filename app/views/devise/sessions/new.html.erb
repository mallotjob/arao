<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 flex items-center justify-center p-4 relative">
  <!-- Language Selector -->
  <div class="absolute top-4 right-4 z-10">
    <div class="relative group">
      <button class="flex items-center space-x-2 px-4 py-2 bg-white rounded-lg shadow-sm border border-slate-200 hover:shadow-md transition-all duration-200">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path>
        </svg>
        <span class="text-sm font-medium text-slate-700">
          <%= t("language.names.#{I18n.locale}", default: I18n.locale.to_s.upcase) %>
        </span>
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>

      <div class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-slate-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-20">
        <div class="py-1">
          <%= link_to url_for(locale: :en), class: "flex items-center px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
            <span class="mr-3">🇺🇸</span> <%= t("language.names.en") %>
          <% end %>
          <%= link_to url_for(locale: :fr), class: "flex items-center px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
            <span class="mr-3">🇫🇷</span> <%= t("language.names.fr") %>
          <% end %>
          <%= link_to url_for(locale: :mg), class: "flex items-center px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
            <span class="mr-3">🇲🇬</span> <%= t("language.names.mg") %>
          <% end %>
          <%= link_to url_for(locale: :"zh-CN"), class: "flex items-center px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 transition-colors" do %>
            <span class="mr-3">🇨🇳</span> <%= t("language.names.zh-CN") %>
          <% end %>
        </div>
      </div>
    </div>
  </div>


  <div class="w-full max-w-md">
    <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-8">
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-2xl shadow-lg mb-4">
          <%= image_tag "favicon.png", alt: "Logo", class: "w-10 h-10 object-contain" %>
        </div>
        <h1 class="text-3xl font-bold text-slate-900 mb-2">
          <%= t('welcome') %>
        </h1>
        <p class="text-slate-600">
          <%= t('login_subtitle') %>
        </p>
      </div>
      <%= form_for(resource, as: resource_name, html: { class: "max-w-md mx-auto" }, url: session_path(resource_name)) do |f| %>
        <div class="relative z-0 w-full mb-5 group">
          <%= f.text_field :login, placeholder: " ",
            class: "block py-2.5 px-0 w-full text-sm text-heading bg-transparent border-0 border-b-2
            border-default-medium appearance-none focus:outline-none focus:ring-0 focus:border-brand peer",
            autocomplete: "username", autofocus: true, required: true %>
          <%= f.label :login, t('labels.username'),
            class: "absolute text-sm text-body duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0]
            peer-focus:start-0 peer-focus:text-fg-brand peer-placeholder-shown:scale-100
            peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6
            rtl:peer-focus:translate-x-1/4 rtl:peer-focus:left-auto" %>
        </div>

        <div class="relative z-0 w-full mb-5 group">
          <%= f.password_field :password, placeholder: " ",
            class: "block py-2.5 px-0 w-full text-sm text-heading bg-transparent border-0 border-b-2
            border-default-medium appearance-none focus:outline-none focus:ring-0 focus:border-brand peer",
            autocomplete: "current-password", required: true %>
          <%= f.label :password, t('labels.password'),
            class: "absolute text-sm text-body duration-300 transform -translate-y-6 scale-75 top-3 -z-10 origin-[0]
            peer-focus:start-0 peer-focus:text-fg-brand peer-placeholder-shown:scale-100
            peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-6 rtl:peer-focus:translate-x-1/4 rtl:peer-focus:left-auto" %>
        </div>

        <% if devise_mapping.rememberable? %>
        <div class="flex items-center mb-5">
            <%= f.check_box :remember_me, class: "w-4 h-4 border border-default-medium rounded-xs
              bg-neutral-secondary-medium focus:ring-2 focus:ring-brand-soft", value: "" %>
            <%= f.label :remember_me, t('labels.remember'), class: "ms-2 text-sm font-medium text-heading" %>
        </div>
        <% end %>


        <div class="actions">
          <%= f.submit t('labels.login'),
              class: "w-full bg-gradient-to-br from-blue-500 to-indigo-600 text-white font-medium py-2 px-4
              rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:ring-offset-2
              transition duration-200 cursor-pointer hover:bg-gradient-to-br hover:from-blue-300 hover:to-indigo-400" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>





